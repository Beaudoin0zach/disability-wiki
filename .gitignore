# Hugo build files
/public/
/resources/
/.hugo_build.lock

# Vestigial content from the prior project (NY-23 Accountability Tracker / Hugo).
# Not part of the Disability Wiki; removed from the wiki + repo on 2026-06-08.
/content/
/archetypes/

# OS files
.DS_Store
Thumbs.db

# Editor files
*.swp
*.swo
*~
.vscode/
.idea/

# Environment and secrets - NEVER commit these
.env
.env.local
.env.*.local
*.pem
*.key
secrets/
credentials/

# Docker volumes and data
wiki_data/
wiki_db_data/

# Backups - never commit database dumps or archives
backups/
!backups/.gitkeep
*.sql
*.sql.gz
*.dump
*.bak
# ...but schema migrations are source, not dumps
!site/supabase/migrations/
!site/supabase/migrations/*.sql

# Python cache
__pycache__/
*.pyc
*.pyo
.pytest_cache/
venv/
.venv/

# Reports and generated files - may contain sensitive paths or data
link_validation_report.json
link_validation_report.txt
*.log
validation_*.txt
validation_*.json

# Temporary files
*.tmp
*.temp
.tmp/
.temp/

# Node modules (if any)
node_modules/

# Claude Code: ignore local config/secrets globally, but DO track project skills.
# (Overrides the global ~/.gitignore_global ".claude/" rule.)
!.claude/
.claude/*
!.claude/skills/
!.claude/skills/**
# track the shared project settings (hooks) — local overrides stay ignored below
!.claude/settings.json
# still keep local settings/secrets and transient workspaces out
.claude/settings.local.json
.claude/skill-workspaces/
description_fix_report.txt

# wrangler local dev state
.wrangler/
