# Cloudflare Pages headers.
# The service worker must never be served stale from the edge — a cached sw.js
# would pin users to an old precache after a life-safety content fix.
/sw.js
  Cache-Control: no-cache
/manifest.webmanifest
  Cache-Control: no-cache
# The OTA update manifest has the same property for the native app: served stale,
# it would pin installed apps to old crisis content after a fix ships.
/ota/*
  Cache-Control: no-cache
